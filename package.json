{
  "name": "@caor/iwinv-alimtalk",
  "version": "0.1.0",
  "description": "Dependency-free Node 26 ESM library and CLI for the iwinv Alimtalk API.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "bin": {
    "iwinv-alimtalk": "./dist/src/cli.js"
  },
  "files": [
    "dist/src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/src/cli.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "iwinv",
    "alimtalk",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.9.3"
  }
}
