{
  "name": "iwinv-alimtalk-cli",
  "version": "0.1.0",
  "description": "Dependency-free Node 26 ESM CLI for the iwinv Alimtalk API.",
  "type": "module",
  "bin": {
    "iwinv-alimtalk": "./dist/src/cli.js"
  },
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/src/cli.js",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "keywords": [
    "iwinv",
    "alimtalk",
    "cli"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^25.9.2",
    "typescript": "^5.9.3"
  }
}
