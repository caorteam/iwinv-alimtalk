{
  "name": "@caor/iwinv-alimtalk",
  "version": "0.2.2",
  "description": "Dependency-free Node 22+ ESM library and CLI for the iwinv Alimtalk API.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caorteam/iwinv-alimtalk.git"
  },
  "homepage": "https://github.com/caorteam/iwinv-alimtalk#readme",
  "bugs": {
    "url": "https://github.com/caorteam/iwinv-alimtalk/issues"
  },
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "bin": {
    "iwinv-alimtalk": "./dist/src/bin.js"
  },
  "files": [
    "dist/src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "postbuild": "chmod +x dist/src/bin.js",
    "test": "npm run build && node --test dist/test/*.test.js",
    "test:coverage": "npm run build && node --test --experimental-test-coverage --test-coverage-exclude='dist/test/**' --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100 dist/test/*.test.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,yml,yaml,json}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "iwinv",
    "alimtalk",
    "cli"
  ],
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@types/node": "^25.9.2",
    "eslint": "^9.15.0",
    "eslint-plugin-import": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.4.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.15.0"
  }
}
